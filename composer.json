{
    "name": "xoops/rector-xoops",
    "description": "Rector rules and sets for automated XOOPS module modernisation.",
    "type": "rector-extension",
    "keywords": ["rector", "xoops", "refactoring", "modernization", "static analysis"],
    "license": "GPL-2.0-or-later",
    "homepage": "https://xoops.org",
    "support": {
        "issues": "https://github.com/xoops/rector_xoops/issues",
        "source": "https://github.com/xoops/rector_xoops"
    },
    "require": {
        "php": ">=8.2",
        "rector/rector": "^2.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.64",
        "phpstan/phpstan": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Xoops\\Rector\\": "src/"
        }
    },
    "scripts": {
        "analyse": "phpstan analyse --memory-limit=512M",
        "cs:check": "php-cs-fixer fix --dry-run --diff --config=.php-cs-fixer.dist.php",
        "cs:fix": "php-cs-fixer fix --config=.php-cs-fixer.dist.php",
        "qa": [
            "@cs:check",
            "@analyse"
        ]
    },
    "config": {
        "sort-packages": true
    }
}
